# Server-side proxy target (Next route `app/api-proxy/*` → FastAPI). Default: http://127.0.0.1:8000
BACKEND_URL=http://127.0.0.1:8000

# Optional: browser calls the API URL directly (no /api-proxy). You must configure CORS (ALLOWED_ORIGINS) on the API.
# NEXT_PUBLIC_API_PROXY=false
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
