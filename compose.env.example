# Copy to `.env` in the repo root so `docker compose -f docker-compose.prod.yml` can substitute vars into the API container.
# The file `.env` is gitignored.

ALLOW_LLM_DEMO=false
GROQ_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini

DATA_RETENTION_DAYS=
MAINTENANCE_SECRET=
