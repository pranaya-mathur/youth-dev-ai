# In `next dev`, the app uses same-origin /api-proxy → backend (see next.config.mjs). You usually do not need this unless you turn the proxy off.
# NEXT_PUBLIC_API_PROXY=false
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Where Next proxies /api-proxy in dev (default: http://127.0.0.1:8000)
# BACKEND_URL=http://127.0.0.1:8000
