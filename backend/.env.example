OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional override for https://platform.openai.com/docs/api-reference/moderations
OPENAI_MODERATION_MODEL=

# Groq + LangChain (https://console.groq.com/) — preferred when set unless LLM_PROVIDER=openai
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: force `groq` or `openai`. If BOTH keys are set, Groq wins unless you set e.g. LLM_PROVIDER=openai.
# If coach fails but your OpenAI key works, you probably have a GROQ_API_KEY line—clear it or set LLM_PROVIDER=openai.
LLM_PROVIDER=

ALLOWED_ORIGINS=http://localhost:3000

# Default false: profile/coach need a real LLM key. Set true only for local UI without API keys.
ALLOW_LLM_DEMO=false

# Optional: Postgres for profiles, XP, journal, coach logs (async SQLAlchemy + asyncpg).
# Example after `docker compose up -d` from repo root (see README):
# DATABASE_URL=postgresql+asyncpg://youth:youth@127.0.0.1:5432/youth
DATABASE_URL=

# Optional: purge DB users inactive longer than N days — set BOTH or neither (min 12-char secret).
# POST /api/internal/maintenance/purge-inactive-users with X-Maintenance-Secret and JSON {"confirm":"purge_inactive_users"}
# DATA_RETENTION_DAYS=365
# MAINTENANCE_SECRET=use-at-least-twelve-chars

# Optional: HMAC-SHA256 user auth (recommended for production).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# When set, every user API call must include: X-Youth-Auth-Token: HMAC-SHA256(key=AUTH_SECRET, msg=user_id)
# Without this the server accepts any UUID without verification (dev/demo only).
# AUTH_SECRET=

# Optional: Redis URL for cross-worker rate limiting.
# Without this, rate limits are per-process (insufficient for multi-worker production deploys).
# REDIS_URL=redis://localhost:6379/0
